TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id

# Optional but recommended: keeps purchase tickets under one category
TICKET_CATEGORY_ID=your_ticket_category_channel_id

# Optional: staff role that can view/close all tickets
STAFF_ROLE_ID=your_staff_role_id

# Daily firmware status broadcast (text channel ID, not category)
STATUS_CHANNEL_ID=your_status_text_channel_id

# US timezone for live clock display (default: Eastern Time)
STATUS_TIMEZONE=America/New_York

# Post twice daily at these times (24h format, comma-separated)
STATUS_POST_TIMES=09:00,21:00

# Discount shown in daily status message
STATUS_DM_DISCOUNT=10%